# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
.env
.env.*

# Jupyter
.ipynb_checkpoints/
*.ipynb
# Allow committed notebooks in examples/
!examples/demo/*.ipynb
!examples/comparison/*.ipynb

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.dmypy.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docs build
docs/_build/

# Results / outputs
results/
*.mat
*.frd
site/

# MATLAB (ignore runtime, but not matlab_src/)
matlab/

# MATLAB generated files in matlab_src/
# Keep .png (reference images), ignore generated data
matlab_src/EXAMPLES/**/octave-workspace
matlab_src/EXAMPLES/**/hb_data.mat
matlab_src/EXAMPLES/**/save_data.m
matlab_src/demo/**/*.png
matlab_src/demo/**/*.mat

# Example outputs
examples/**/output/
examples/**/*.mat
examples/**/*.png
examples/**/__pycache__/

# Agent temporary files
agents/.temp/
agents/**/*.log
